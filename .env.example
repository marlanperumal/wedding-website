DATABASE_URL="postgresql://wedding:wedding@localhost:5433/wedding_dev"
ADMIN_PASSPHRASE_HASH=""
COOKIE_SECRET="change-me-to-a-random-32-byte-hex-string"
RESEND_API_KEY=""
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# RSVP edit/submit deadline (ISO 8601). After this, the RSVP form is read-only
# and guests see only their summary. Leave unset locally to keep RSVP always open.
RSVP_DEADLINE="2026-10-15T23:59:59+02:00"

# Local email catcher (Mailpit). When SMTP_HOST is set, emails are sent via
# SMTP to the catcher instead of Resend — view them at http://localhost:8025.
# Leave SMTP_HOST unset in production so Resend is used.
SMTP_HOST="localhost"
SMTP_PORT="1025"
